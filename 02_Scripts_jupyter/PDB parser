    "import urllib.request\n",
    "from Bio.PDB import PDBParser\n",
    "\n",
    "## Uso la herramienta de lector de url\n",
    "\n",
    "urllib.request.urlretrieve(\"https://files.rcsb.org/download/4INS.pdb\", \"4INS.pdb\")\n",
    "\n",
    "lector = PDBParser(QUIET=True)\n",
    "\n",
    "estructura = lector.get_structure(\"Mi_Insulina\", \"4INS.pdb\")\n",
    "\n",
    "for cadena in estructura[0]:\n",
    "    print(cadena.id)\n",
    "\n",
    "cadena_A = estructura[0][\"A\"]\n",
    "n_residuos_A = len(cadena_A)\n",
    "print(f\"La cadena A tiene {n_residuos_A} residuos totales \")\n",
    "\n",
    "## Ahora contamos los aminoácidos reales\n",
    "\n",
    "n_aas = 0\n",
    "n_resto = 0\n",
    "for residuo in cadena_A:\n",
    "    if residuo.id[0] == \" \":\n",
    "        n_aas = n_aas + 1\n",
    "    else:\n",
    "        n_resto = n_resto + 1\n",
    "\n",
    "print(f\"La cadena A de la insulina humana tiene {n_aas} residuos aminoacídicos y {n_resto} residuos ruidosos (por ejemplo agua)\")"
   ]
