   "source": [
    "import pandas as pd\n",
    "\n",
    "# 1. Datos REALES extraídos de UniProt (separados por tabulaciones)\n",
    "datos_reales = \"\"\"Entry\tEntry Name\tProtein names\tGene Names\tLength\n",
    "P04637\tP53_HUMAN\tCellular tumor antigen p53\tTP53\t393\n",
    "P38398\tBRCA1_HUMAN\tBreast cancer type 1 susceptibility protein\tBRCA1\t1863\n",
    "P00533\tEGFR_HUMAN\tEpidermal growth factor receptor\tEGFR\t1210\n",
    "P01308\tINS_HUMAN\tInsulin\tINS\t110\n",
    "P68871\tHBB_HUMAN\tHemoglobin subunit beta\tHBB\t147\n",
    "\"\"\"\n",
    "\n",
    "# Guardamos el archivo en tu disco duro para que sea real\n",
    "with open(\"uniprot_real.tsv\", \"w\", encoding=\"utf-8\") as archivo:\n",
    "    archivo.write(datos_reales)\n",
    "\n",
    "# 2. LEER EL TSV \n",
    "\n",
    "# IMPORTANTE: Como es un TSV, le avisamos a Pandas que el separador es un tabulador (sep=\"\\t\")\n",
    "df_uniprot = pd.read_csv(\"uniprot_real.tsv\", sep=\"\\t\")\n",
    "\n",
    "print(\"--- TABLA REAL DE UNIPROT ---\")\n",
    "display(df_uniprot)\n",
    "\n",
    "\n",
    "# 3. FILTRAR DATOS\n",
    "print(\"\\n--- RESULTADO DEL FILTRO: Solo proteínas gigantes (> 500 aa) ---\")\n",
    "\n",
    "filtro_gigantes = df_uniprot[df_uniprot[\"Length\"] > 500]\n",
    "\n",
    "display(filtro_gigantes)"
   ]
  }
