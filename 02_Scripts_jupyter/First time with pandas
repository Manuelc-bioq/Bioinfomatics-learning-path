    "import pandas as pd\n",
    "\n",
    "# Simulamos que descargamos un CSV de una base de datos creando uno pequeño\n",
    "texto_csv = \"\"\"Nombre_Proteina,Gen,Longitud_AA,Enfermedad_Asociada\n",
    "p53,TP53,393,Cancer\n",
    "Hemoglobina_beta,HBB,147,Anemia Falciforme\n",
    "CFTR,CFTR,1480,Fibrosis Quistica\n",
    "BRCA1,BRCA1,1863,Cancer de Mama\n",
    "\"\"\"\n",
    "\n",
    "# Guardamos ese texto en dataset_proteínas.csv y lo convertimos en la variable archivo\n",
    "with open(\"dataset_proteinas.csv\", \"w\") as archivo:\n",
    "    archivo.write(texto_csv)\n",
    "\n",
    "# Le pedimos a pandas (pd) que lea el archivo y lo guarde en la variable \"tabla\"\n",
    "tabla = pd.read_csv(\"dataset_proteinas.csv\")\n",
    "\n",
    "# Mostramos la tabla formateada\n",
    "display(tabla)"
